ENCRYPTION_KEY=your-fernet-derived-key-here
DATABASE_PATH=/app/db/agents.db

# Todas las credenciales de Huawei Cloud, SSH y Kubernetes ahora se configuran
# desde la pestaña "Configuracion" del Dashboard web (http://localhost:3000).
#
# Las siguientes variables de entorno son FALLBACKS opcionales
# (solo se usan si no se ha configurado via UI):
#
# TF_VAR_region=la-north-2
# TF_VAR_access_key=your-hwc-access-key
# TF_VAR_secret_key=your-hwc-secret-key
# TF_VAR_project_id=your-hwc-project-id
# SSH_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
# SSH_USERNAME=root
# KUBECONFIG_CONTENT=apiVersion: v1\n...
# HELM_RELEASE=my-app
# HELM_CHART=stable/nginx
