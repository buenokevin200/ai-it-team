ENCRYPTION_KEY=your-fernet-derived-key-here
DATABASE_PATH=/app/db/agents.db

# Todas las credenciales ahora se configuran desde la pestaña
# "Configuracion" del Dashboard web (http://localhost:3000).
#
# Categorias disponibles en la UI:
#
# Inteligencia Artificial (Deepseek):
#   - ai_deepseek_api_key
#   - ai_deepseek_base_url  (default: https://api.deepseek.com)
#   - ai_deepseek_model     (default: deepseek-chat)
#
# Huawei Cloud:
#   - hwc_access_key
#   - hwc_secret_key
#   - hwc_region
#   - hwc_project_id
#
# SSH:
#   - ssh_private_key  (RSA PEM)
#   - ssh_username     (default: root)
#   - ssh_password     (alternativa a key)
#
# Kubernetes / CCE:
#   - kubeconfig
#   - helm_release
#   - helm_chart
#
# Variables de entorno como FALLBACK (opcionales):
# TF_VAR_region=la-north-2
# TF_VAR_access_key=
# TF_VAR_secret_key=
# TF_VAR_project_id=
# SSH_PRIVATE_KEY=
# SSH_USERNAME=root
# SSH_PASSWORD=
# KUBECONFIG_CONTENT=
# HELM_RELEASE=
# HELM_CHART=
